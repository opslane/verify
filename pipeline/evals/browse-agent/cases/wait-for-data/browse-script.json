{
  "steps": [
    {
      "match": "goto ",
      "stdout": "Reports page opened.\n",
      "exitCode": 0
    },
    {
      "match": "snapshot",
      "stdout": "Loading reports...\n",
      "exitCode": 0
    },
    {
      "match": "wait ",
      "stdout": "Reports loaded. Monthly revenue and Active users rows are visible.\n",
      "exitCode": 0,
      "sleepMs": 2500
    },
    {
      "match": "snapshot",
      "stdout": "@e1 [row] \"Monthly revenue\"\n@e2 [row] \"Active users\"\n",
      "exitCode": 0
    },
    {
      "match": "screenshot ",
      "stdout": "Screenshot saved.\n",
      "exitCode": 0
    }
  ]
}
